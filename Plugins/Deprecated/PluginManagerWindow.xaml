<Window x:Class="Layouter.Plugins.PluginManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Layouter.Plugins"
        mc:Ignorable="d"
        Title="插件管理" Height="400" Width="640" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0" HorizontalAlignment="Right">
            <Button x:Name="ImportButton" Content="导入插件" Width="80" Margin="5" Click="ImportButton_Click"/>
            <Button x:Name="EnableButton" Content="启用" Width="80" Margin="5" Click="EnableButton_Click"/>
            <Button x:Name="DisableButton" Content="禁用" Width="80" Margin="5" Click="DisableButton_Click"/>
            <Button x:Name="RemoveButton" Content="删除" Width="80" Margin="5" Click="RemoveButton_Click"/>
            <Button x:Name="CloseButton" Content="关闭" Width="80" Margin="5" Click="CloseButton_Click"/>
        </StackPanel>
        <DataGrid Grid.Row="1" x:Name="PluginsDataGrid" AutoGenerateColumns="False" IsReadOnly="True" 
                  SelectionMode="Single" SelectionChanged="PluginsDataGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="启用" Binding="{Binding IsEnabled}" Width="50"/>
                <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="120"/>
                <DataGridTextColumn Header="版本" Binding="{Binding Version}" Width="80"/>
                <DataGridTextColumn Header="作者" Binding="{Binding Author}" Width="100"/>
                <DataGridTextColumn Header="描述" Binding="{Binding Description}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</Window>
